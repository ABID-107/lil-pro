<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>

<body class="bg-gray-900 text-white p-10">
    <div class="form flex flex-col items-center gap-4 mb-10">
        <form action="/create" method="post" class="flex flex-col items-center gap-4">
            <input class="rounded-lg bg-gray-700 placeholder:text-gray-500 px-4 py-2" type="text" placeholder="Enter a task..." name="title"></input>
            <textarea class="rounded-lg bg-gray-700 w-full placeholder:text-gray-500 px-4 py-2 resize-none"
                placeholder="Enter a description..." name="description"></textarea>
            <button type="submit" class="btn bg-blue-500 w-32 rounded-lg p-2">Add Task</button>
        </form>
    </div>
    <div class="tasks flex flex-row justify-center gap-4">
        <%if(files.length>0){%>
            <% files.forEach(val=>{ %>
                <div class="task w-80 bg-gray-800 p-4 rounded-lg mb-4">
                    <h1 class="text-xl font-bold">
                        <%= val%>
                    </h1>
                    <div class="flex justify-between ">
                        <a href="/file/<%= val %>" class="text-blue-500 hover:underline">Read More</a>
                        <a href="/edit/<%= val %>" class="text-zinc-500 hover:underline">Edit</a>
                        <a href="/delete/<%= val %>" class="text-red-500 hover:underline">Delete</a>
                    </div>
                </div>
                <% }) %>
                    <%} else {%>
                        <h1 class="text-xl font-bold">No tasks available</h1>
                        <% } %>
    </div>
</body>

</html>