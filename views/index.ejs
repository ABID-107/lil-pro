<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>

<body class="bg-gray-900 text-white p-10">
    <div class="form flex flex-col items-center gap-4 mb-10">
        <form action="/" class="flex flex-col gap-4">
            <input class="border rounded-lg" type="text" placeholder="Enter a task...">
            <input class="border rounded-lg" type="text" placeholder="Enter a description...">
            <button type="submit" class="btn bg-blue-500 w-auto rounded-lg">Add Task</button>
        </form>
    </div>
    <div class="tasks flex flex-col items-center gap-4">
        <div class="task w-80 bg-gray-800 p-4 rounded-lg mb-4">
            <h1 class="text-xl font-bold">Tasks</h1>
            <div class="flex justify-between ">
                <a href="" class="text-blue-500 hover:underline">Read More</a>
                <a href="" class="text-zinc-500 hover:underline">Edit</a>
                <a href="" class="text-red-500 hover:underline">Delete</a>
            </div>
        </div>
    </div>
</body>

</html>